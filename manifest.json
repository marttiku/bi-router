{
  "manifest_version": 3,
  "name": "Strava Heatmap Route Planner",
  "version": "1.2.0",
  "description": "Plan cycling routes using Strava's global heatmap overlay and export to GPX for Google Maps",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "*://*.strava.com/*",
    "*://gis.tallinn.ee/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Route Planner",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.strava.com/maps/global-heatmap*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
